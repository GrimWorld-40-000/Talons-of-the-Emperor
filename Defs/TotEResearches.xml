	<ResearchProjectDef ParentName="GW_SM_TotETechBase">
		<defName>GW_TotE_Custodes</defName>
		<label>Legio Custodes</label>
		<description>The Legio Custodes, also known as the Adeptus Custodes, is an elite force in Warhammer 40,000. They're the Emperor's personal bodyguards, clad in golden armor and unmatched in skill, protecting key figures and locations of the Imperium with unwavering loyalty.</description>
        <baseCost>8500</baseCost>
		<prerequisites>
			<li>AdvancedFabrication</li>
			<li>GW_SM_CustodesFabrication</li>
			<li MayRequire="happypurging.ageofdarkness">GW_SM_AstartesMedium</li>
		</prerequisites>
		<researchViewX>14.50</researchViewX>
		<researchViewY>3.90</researchViewY>
		<modExtensions>
            <li Class="GW_Frame.DefModExtension_ExtraPrerequisiteActions">
                <StudyLocation>GW_Cogitator</StudyLocation>
                <ItemStudyRequirements>
                    <li Class="GW_Frame.StudyRequirement">
                        <StudyObject>GW_STC_Fragment</StudyObject>
                        <NumberRequired>3</NumberRequired>
                    </li>    
                </ItemStudyRequirements>
            </li>
        </modExtensions>
	</ResearchProjectDef>

